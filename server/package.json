{
  "private": true,
  "name": "@space-shooter/server",
  "version": "1.0.0",
  "description": "Space Shooter Casino Game - Authoritative Server",
  "type": "module",
  "main": "build/index.js",
  "engines": {
    "node": ">= 20.9.0"
  },
  "scripts": {
    "start": "tsx watch src/index.ts",
    "loadtest": "tsx scripts/loadtest.ts",
