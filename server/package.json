    "clean": "rimraf build",
    "test": "mocha -r tsx test/**.test.ts --exit --timeout 15000"
  },
  "devDependencies": {
    "@colyseus/loadtest": "^0.17.7",
    "@colyseus/sdk": "^0.17.35",
    "@colyseus/testing": "^0.17.10",
    "@types/express": "^4.17.1",
    "@types/mocha": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.11",
    "mocha": "^11.7.5",
    "rimraf": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.0",
    "@colyseus/tools": "^0.17.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@space-shooter/shared": "^1.0.0",
    "colyseus": "^0.17.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "pg": "^8.20.0",
    "prisma": "^7.5.0"
  }
}
