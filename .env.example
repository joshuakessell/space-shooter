# Database connection (required)
DATABASE_URL=postgresql://spaceshooter:spaceshooter_dev@localhost:5432/spaceshooter?schema=public

# Server port (optional, defaults to 2567)
PORT=2567

# Node environment
NODE_ENV=development

# Monitor dashboard auth (required in production; monitor disabled if unset)
MONITOR_PASSWORD=

# Colyseus settings
COLYSEUS_PRESENCE_URL=redis://localhost:6379
